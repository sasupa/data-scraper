# Capture-side environment.
# Copy to capture/.env (gitignored) on the workstation that runs the capture.
# Different from the server-side .env: this is what the laptop needs to
# reach the dataScraper VPS over Tailscale and authenticate.

# Where to POST captured payloads. Use the VPS's Tailscale hostname or IP.
# Example: http://salikortti-4gb-hel1-1:3030  or  http://100.109.216.118:3030
DATASCRAPER_URL=http://REPLACE_WITH_TAILSCALE_HOST:3030

# Same INTERNAL_TOKEN that's set in the server's .env. Generate once on the
# server (openssl rand -hex 32), then copy here. Rotate by updating both
# files and restarting the server.
INTERNAL_TOKEN=REPLACE_WITH_TOKEN_FROM_SERVER_DOTENV
