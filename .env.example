# Copy to .env and fill in. Never commit .env.

NODE_ENV=development
HOST=127.0.0.1
PORT=3030
LOG_LEVEL=info

# Shared secret for X-Internal-Token. Generate with: openssl rand -hex 32
INTERNAL_TOKEN=replace-me-with-32-byte-hex

# SQLite location (relative to repo root or absolute)
DB_PATH=./data/scraper.db

# --- Providers ---
# Each provider has a mode: mock | scrape | live
# Start in mock; flip to live once credentials are in place.

NORDNET_MODE=mock
NORDNET_API_KEY=
NORDNET_PRIVATE_KEY_PATH=

INSTAGRAM_MODE=mock

YOUTUBE_MODE=mock
YOUTUBE_API_KEY=

ALPHAVANTAGE_MODE=mock
ALPHAVANTAGE_API_KEY=
