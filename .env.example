# Copy to .env and fill in. Never commit .env.

NODE_ENV=development
HOST=127.0.0.1
PORT=3030
LOG_LEVEL=info

# Server-to-server credential. Sent by consumers as X-Internal-Token.
# Generate with: openssl rand -hex 32
INTERNAL_TOKEN=replace-me-with-32-byte-hex

# Human-typed credential for the /admin UI (Basic auth, username is always "admin").
# Kept separate from INTERNAL_TOKEN on purpose: different leak surfaces, different
# rotation cadence. Generate with: openssl rand -base64 24
ADMIN_PASSWORD=replace-me-with-base64-24

# SQLite location (relative to repo root or absolute)
DB_PATH=./data/scraper.db

# --- Providers ---
# Each provider has a mode: mock | scrape | live
# Start in mock; flip to live once credentials are in place.

NORDNET_MODE=mock
NORDNET_API_KEY=
NORDNET_PRIVATE_KEY_PATH=

INSTAGRAM_MODE=mock

YOUTUBE_MODE=mock
YOUTUBE_API_KEY=

ALPHAVANTAGE_MODE=mock
ALPHAVANTAGE_API_KEY=
